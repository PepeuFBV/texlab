{
    "name": "TeX Dev Container",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.shell.linux": "/bin/bash",
                "latex-workshop.latex.autoBuild.run": "onFileChange",
                "latex-workshop.latex.watch.files.usePolling": true,
                "latex-workshop.latexindent.path": "/usr/local/bin/latexindent",
                "latex-workshop.formatting.latexindent.path": "/usr/local/bin/latexindent",
            },
            "extensions": [
                "james-yu.latex-workshop"
            ]
        }
    },
    "runArgs": [
        "--env-file",
        ".devcontainer/.env.resources"
    ],
    "postCreateCommand": "(latexindent --version || latexindent.pl --version) > /tmp/devcontainer-latexindent.log 2>&1 || true",
    "postStartCommand": ".devcontainer/start-watchers.sh || true",
    "remoteUser": "vscode"
}